rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 64;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /transactions/{id} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidId(id) 
          && incoming().keys().hasAll(['id', 'description', 'amount', 'type', 'category', 'date', 'userId'])
          && incoming().userId == request.auth.uid;
        allow delete: if isOwner(userId);
      }

      match /recurring_transactions/{id} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidId(id)
          && incoming().keys().hasAll(['id', 'description', 'amount', 'type', 'category', 'frequency', 'startDate', 'lastProcessedDate', 'userId'])
          && incoming().userId == request.auth.uid;
        allow delete: if isOwner(userId);
      }

      match /categories/{id} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidId(id)
          && incoming().keys().hasAll(['id', 'name', 'icon', 'type', 'color', 'userId'])
          && incoming().userId == request.auth.uid;
        allow delete: if isOwner(userId);
      }

      match /tasks/{id} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidId(id)
          && incoming().keys().hasAll(['id', 'title', 'date', 'startTime', 'endTime', 'completed', 'userId'])
          && incoming().userId == request.auth.uid;
        allow delete: if isOwner(userId);
      }

      match /targets/{id} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidId(id)
          && incoming().keys().hasAll(['id', 'title', 'targetValue', 'currentValue', 'unit', 'category', 'userId'])
          && incoming().userId == request.auth.uid;
        allow delete: if isOwner(userId);
      }

      match /unlocked_achievements/{id} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidId(id)
          && incoming().keys().hasAll(['id', 'unlockedAt', 'userId'])
          && incoming().userId == request.auth.uid;
        allow delete: if isOwner(userId);
      }

      match /notification_settings/{id} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidId(id)
          && incoming().keys().hasAll(['id', 'type', 'enabled', 'frequency', 'userId'])
          && incoming().userId == request.auth.uid;
        allow delete: if isOwner(userId);
      }

      match /daily_quote/{id} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && isValidId(id)
           && incoming().keys().hasAll(['id', 'text', 'author', 'field', 'date', 'userId'])
           && incoming().userId == request.auth.uid;
      }

      match /ai_plan/{id} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && isValidId(id)
           && incoming().keys().hasAll(['date', 'items', 'userId'])
           && incoming().userId == request.auth.uid;
      }

      match /budgets/{id} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidId(id)
          && incoming().keys().hasAll(['id', 'categoryId', 'amount', 'period', 'userId'])
          && incoming().userId == request.auth.uid;
        allow delete: if isOwner(userId);
      }

      match /savings_goals/{id} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidId(id)
          && incoming().keys().hasAll(['id', 'title', 'targetAmount', 'currentAmount', 'userId'])
          && incoming().userId == request.auth.uid;
        allow delete: if isOwner(userId);
      }

      match /habits/{id} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidId(id)
          && incoming().keys().hasAll(['id', 'title', 'category', 'targetCount', 'unit', 'userId'])
          && incoming().userId == request.auth.uid;
        allow delete: if isOwner(userId);
      }

      match /habit_logs/{id} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidId(id)
          && incoming().keys().hasAll(['id', 'habitId', 'date', 'completedCount', 'userId'])
          && incoming().userId == request.auth.uid;
        allow delete: if isOwner(userId);
      }

      match /in_app_notifications/{id} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(id)
          && incoming().userId == request.auth.uid;
        allow delete: if isOwner(userId);
      }

      match /journals/{id} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidId(id)
          && incoming().keys().hasAll(['id', 'title', 'content', 'date', 'mood', 'userId'])
          && incoming().userId == request.auth.uid;
        allow delete: if isOwner(userId);
      }
    }
  }
}
