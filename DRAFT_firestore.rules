rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Global Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Helpers ---

    function isValidTransaction(data) {
      return data.keys().hasAll(['id', 'description', 'amount', 'type', 'category', 'date', 'userId'])
        && data.id is string && data.id.size() <= 128
        && data.description is string && data.description.size() <= 500
        && data.amount is number
        && data.type in ['income', 'expense']
        && data.category is string && data.category.size() <= 128
        && data.date is string && data.date.size() <= 20
        && data.userId == request.auth.uid;
    }

    function isValidRecurringTransaction(data) {
      return data.keys().hasAll(['id', 'description', 'amount', 'type', 'category', 'frequency', 'startDate', 'lastProcessedDate', 'userId'])
        && data.id is string && data.id.size() <= 128
        && data.amount is number
        && data.type in ['income', 'expense']
        && data.frequency in ['daily', 'weekly', 'monthly', 'yearly']
        && data.userId == request.auth.uid;
    }

    function isValidCategory(data) {
      return data.keys().hasAll(['id', 'name', 'icon', 'type', 'color', 'userId'])
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 100
        && data.icon is string && data.icon.size() <= 50
        && data.type in ['income', 'expense']
        && data.color is string && data.color.size() <= 20
        && data.userId == request.auth.uid;
    }

    function isValidTask(data) {
      return data.keys().hasAll(['id', 'title', 'date', 'startTime', 'endTime', 'completed', 'userId'])
        && data.id is string && data.id.size() <= 128
        && data.title is string && data.title.size() <= 200
        && data.completed is boolean
        && data.userId == request.auth.uid;
    }

    function isValidTarget(data) {
      return data.keys().hasAll(['id', 'title', 'targetValue', 'currentValue', 'unit', 'category', 'userId'])
        && data.id is string && data.id.size() <= 128
        && data.title is string && data.title.size() <= 200
        && data.targetValue is number
        && data.currentValue is number
        && data.userId == request.auth.uid;
    }

    function isValidAchievement(data) {
      return data.keys().hasAll(['id', 'unlockedAt', 'userId'])
        && data.id is string && data.id.size() <= 128
        && data.unlockedAt is string
        && data.userId == request.auth.uid;
    }

    function isValidNotificationSetting(data) {
      return data.keys().hasAll(['id', 'type', 'enabled', 'frequency', 'userId'])
        && data.id is string && data.id.size() <= 128
        && data.enabled is boolean
        && data.userId == request.auth.uid;
    }

    function isValidQuote(data) {
      return data.keys().hasAll(['id', 'text', 'author', 'field', 'date', 'userId'])
        && data.id is string && data.id.size() <= 128
        && data.userId == request.auth.uid;
    }

    function isValidAIPlan(data) {
      return data.keys().hasAll(['date', 'items', 'userId'])
        && data.date is string
        && data.items is list
        && data.userId == request.auth.uid;
    }

    function isValidBudget(data) {
      return data.keys().hasAll(['id', 'categoryId', 'amount', 'period', 'userId'])
        && data.id is string && data.id.size() <= 128
        && data.amount is number
        && data.userId == request.auth.uid;
    }

    function isValidSavingsGoal(data) {
      return data.keys().hasAll(['id', 'title', 'targetAmount', 'currentAmount', 'userId'])
        && data.id is string && data.id.size() <= 128
        && data.targetAmount is number
        && data.currentAmount is number
        && data.userId == request.auth.uid;
    }

    // --- Routes ---

    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /transactions/{transactionId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(transactionId) && isValidTransaction(incoming());
        allow update: if isOwner(userId) && isValidId(transactionId) && isValidTransaction(incoming());
        allow delete: if isOwner(userId);
      }

      match /recurring_transactions/{transactionId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(transactionId) && isValidRecurringTransaction(incoming());
        allow update: if isOwner(userId) && isValidId(transactionId) && isValidRecurringTransaction(incoming());
        allow delete: if isOwner(userId);
      }

      match /categories/{categoryId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(categoryId) && isValidCategory(incoming());
        allow update: if isOwner(userId) && isValidId(categoryId) && isValidCategory(incoming());
        allow delete: if isOwner(userId);
      }

      match /tasks/{taskId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(taskId) && isValidTask(incoming());
        allow update: if isOwner(userId) && isValidId(taskId) && isValidTask(incoming());
        allow delete: if isOwner(userId);
      }

      match /targets/{targetId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(targetId) && isValidTarget(incoming());
        allow update: if isOwner(userId) && isValidId(targetId) && isValidTarget(incoming());
        allow delete: if isOwner(userId);
      }

      match /unlocked_achievements/{achievementId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(achievementId) && isValidAchievement(incoming());
        allow update: if isOwner(userId) && isValidId(achievementId) && isValidAchievement(incoming());
        allow delete: if isOwner(userId);
      }

      match /notification_settings/{settingId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(settingId) && isValidNotificationSetting(incoming());
        allow update: if isOwner(userId) && isValidId(settingId) && isValidNotificationSetting(incoming());
        allow delete: if isOwner(userId);
      }

      match /daily_quote/current {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && isValidQuote(incoming());
      }

      match /ai_plan/current {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && isValidAIPlan(incoming());
      }

      match /budgets/{budgetId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(budgetId) && isValidBudget(incoming());
        allow update: if isOwner(userId) && isValidId(budgetId) && isValidBudget(incoming());
        allow delete: if isOwner(userId);
      }

      match /savings_goals/{goalId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(goalId) && isValidSavingsGoal(incoming());
        allow update: if isOwner(userId) && isValidId(goalId) && isValidSavingsGoal(incoming());
        allow delete: if isOwner(userId);
      }
    }
  }
}
